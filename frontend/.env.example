# Vanguard AERO Frontend Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL (set this to your Render backend URL after deployment)
VITE_API_URL=https://your-render-backend.onrender.com/api

# Backend Socket.IO URL (same as your Render backend URL)
VITE_SOCKET_URL=https://your-render-backend.onrender.com
